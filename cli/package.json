{
    "name": "@stelline/cli",
    "version": "0.0.0",
    "private": true,
    "description": "Stelline CLI",
    "type": "module",
    "packageManager": "bun@1.3.0",
    "bin": {
        "stelline": "./dist/cli.js"
    },
    "files": [
        "dist"
    ],
    "engines": {
        "bun": ">=1.3.0"
    },
    "scripts": {
        "build": "bunx tsc -p tsconfig.json",
        "check": "bunx tsc -p tsconfig.json --noEmit",
        "dev": "bun --watch ./src/cli.ts",
        "help": "bun run build && bun ./dist/cli.js --help",
        "report": "bun run build && bun ./dist/cli.js report",
        "topo": "bun run build && bun ./dist/cli.js topo"
    },
    "dependencies": {
        "@opentui/core": "^0.1.97",
        "@opentui/react": "^0.1.97",
        "bun-ffi-structs": "^0.1.2",
        "commander": "^12.1.0",
        "react": "^19.1.1",
        "react-devtools-core": "^7.0.1",
        "ws": "^8.18.3"
    },
    "devDependencies": {
        "@types/node": "^20.17.30",
        "@types/react": "^19.1.2",
        "bun-types": "^1.3.11",
        "typescript": "^5.8.2"
    }
}
