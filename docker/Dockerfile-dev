FROM stelline-base:latest

ARG DEBIAN_FRONTEND=noninteractive

WORKDIR /home/sdk

RUN apt update && \
    apt install --no-install-recommends -y \
        iproute2 htop btop nvtop nload pciutils \
        curl \
        && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://code-server.dev/install.sh | sh

RUN python3 -m pip install --no-cache-dir "jupyterlab>=4,<5" \
                                           "notebook>=7,<8" \
                                           "jupyter-server>=2,<3" \
                                           "jupyterlab-nvdashboard" \
                                           "rich"

RUN cat <<'EOF' >/usr/local/bin/dev-entrypoint.sh
#!/bin/sh
set -eu

case "${STELLINE_DEV_INTERFACE:-jupyter}" in
  jupyter)
    exec jupyter lab \
      --ServerApp.ip=0.0.0.0 \
      --ServerApp.port="${STELLINE_DEV_PORT:-8888}" \
      --ServerApp.open_browser=False \
      --ServerApp.base_url="${STELLINE_DEV_BASE_URL:-/}" \
      --ServerApp.root_dir="${STELLINE_DEV_ROOT:-/home/sdk}" \
      --ServerApp.token="${JUPYTER_TOKEN:-}" \
      --allow-root
    ;;
  vscode)
    exec code-server \
      --bind-addr "0.0.0.0:${STELLINE_DEV_PORT:-8888}" \
      --base-path "${STELLINE_DEV_BASE_URL:-/}" \
      --auth none \
      "${STELLINE_DEV_ROOT:-/home/sdk}"
    ;;
  *)
    echo "Unsupported STELLINE_DEV_INTERFACE: ${STELLINE_DEV_INTERFACE:-}. Use 'jupyter' or 'vscode'." >&2
    exit 1
    ;;
esac
EOF

RUN chmod +x /usr/local/bin/dev-entrypoint.sh

EXPOSE 8888

ENV STELLINE_DEV_INTERFACE=jupyter
ENV STELLINE_DEV_PORT=8888
ENV STELLINE_DEV_BASE_URL=/
ENV STELLINE_DEV_ROOT=/home/sdk

CMD ["/usr/local/bin/dev-entrypoint.sh"]
