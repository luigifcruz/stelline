#define STELLINE_VERSION_STR "@version@"
#define STELLINE_VERSION_MAJOR @version_major@
#define STELLINE_VERSION_MINOR @version_minor@
#define STELLINE_VERSION_PATCH @version_patch@
#define STELLINE_VERSION_ENCODE(major, minor, patch) ((((major) & 0xffu) << 16) | (((minor) & 0xffu) << 8) | ((patch) & 0xffu))
#define STELLINE_VERSION_CURRENT STELLINE_VERSION_ENCODE(STELLINE_VERSION_MAJOR, STELLINE_VERSION_MINOR, STELLINE_VERSION_PATCH)

// Loaders
